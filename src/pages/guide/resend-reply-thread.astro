---
const title = 'How to Reply Emails in Same Thread with Resend API - Email Reply Builder';
const description = 'Complete guide on keeping email replies in the same Gmail thread when using Resend API. Learn about In-Reply-To, References headers and email threading.';
const keywords = 'resend thread reply, gmail thread, in-reply-to, references header, email threading, resend api guide';
const siteUrl = 'https://tools.eastondev.com/email-reply-builder';
const canonicalUrl = `${siteUrl}/guide/resend-reply-thread`;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: 'How to Reply Emails in Same Thread with Resend API',
  description: 'Learn how to use In-Reply-To and References headers to keep replies in the same Gmail thread when sending via Resend.',
  author: {
    '@type': 'Organization',
    name: 'EastonDev'
  },
  publisher: {
    '@type': 'Organization',
    name: 'EastonDev'
  },
  mainEntityOfPage: canonicalUrl
};
const headerExample = `{
  "headers": {
    "In-Reply-To": "<original-message-id@domain.com>",
    "References": "<parent-id@domain.com> <original-id@domain.com>"
  }
}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="keywords" content={keywords}>
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonicalUrl}>
  <link rel="icon" type="image/png" href="/assets/brand/easton-tools-mark.png">
  <link rel="apple-touch-icon" href="/assets/brand/easton-tools-mark.png">

  <!-- Open Graph -->
  <meta property="og:type" content="article">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="article:section" content="Email Guide">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">

  <!-- Article Structured Data -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
</head>
<body>
  <main>
    <h1>How to Reply Emails in Same Thread with Resend</h1>
    <p><a href="/">← Try Email Reply Builder Now</a></p>

    <section>
      <h2>The Problem</h2>
      <p>
        When you send emails through Resend, replies often don't thread properly in Gmail and other email clients.
      </p>
      <p>Email clients group messages into threads based on specific headers:</p>
      <ul>
        <li><code>In-Reply-To</code> — references the message being replied to</li>
        <li><code>References</code> — chain of all previous message IDs</li>
      </ul>
    </section>

    <section>
      <h2>The Solution</h2>
      <p>Email Reply Builder automatically extracts these headers and includes them in your reply:</p>
      <ol>
        <li>Open the original email in Gmail</li>
        <li>Click <strong>"Show original"</strong> (three dots menu)</li>
        <li>Copy the entire raw email content</li>
        <li>Paste it into Email Reply Builder</li>
        <li>Write your reply and send</li>
      </ol>
    </section>

    <section>
      <h2>Technical Details</h2>
      <p>When sending through Resend API, include these headers:</p>
      <pre><code>{headerExample}</code></pre>
    </section>

    <section>
      <h2>Subject Line</h2>
      <p>Prefix the subject with <code>Re:</code>:</p>
      <pre><code>Original: "Meeting tomorrow"
Reply:    "Re: Meeting tomorrow"</code></pre>
    </section>
  </main>
</body>
</html>

